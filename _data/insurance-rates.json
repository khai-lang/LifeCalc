---
layout: default
title: 4대보험 계산기 2025 — 근로자 부담액 자동 계산
description: 월급/연봉 기준 국민연금·건강보험(장기요양)·고용보험 근로자 부담액을 추정 계산합니다. 연도별 요율 자동 적용.
permalink: /salary/insurances/
---

<p id="rateNotice" class="muted" style="margin:6px 0 14px;"></p>

<form id="ins-form" onsubmit="event.preventDefault(); calcIns();">
  <div style="display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px">

    <label>월 급여(세전, 원)
      <input type="number" id="pay" placeholder="예: 3500000" required>
    </label>

    <label>연봉(세전, 원) (선택)
      <input type="number" id="annual" placeholder="예: 42000000">
      <small class="muted">연봉 입력 시 월 급여로 자동 환산</small>
    </label>

    <label>적용 연도(자동)
      <input type="text" id="year_used" value="자동 적용" readonly>
    </label>

  </div>

  <details style="margin:12px 0;">
    <summary><strong>고급 설정: 요율 보기/수정</strong></summary>

    <div style="display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px;margin-top:10px">
      <label>국민연금(근로자 %)
        <input type="number" id="i_np" step="0.001" placeholder="예: 4.5">
      </label>

      <label>건강보험(근로자 %)
        <input type="number" id="i_hi" step="0.001" placeholder="예: 3.545">
      </label>

      <label>장기요양(% of 건보료)
        <input type="number" id="i_ltc" step="0.001" placeholder="예: 12.95">
      </label>

      <label>고용보험(근로자 %)
        <input type="number" id="i_ei" step="0.001" placeholder="예: 0.9">
      </label>
    </div>

    <small class="muted" style="display:block;margin-top:8px;">
      ※ 요율은 <code>/data/insurance-rates.json</code>에서 자동 적용됩니다. 필요 시 수동으로 수정해도 됩니다.
    </small>
  </details>

  <button class="btn" type="submit">계산</button>
</form>

<div id="ins-out" class="result-box"></div>

<div class="btn-row" style="display:flex;gap:8px;flex-wrap:wrap;margin-top:16px">
  <a class="btn" href="/salary/withholding/">다음: 원천징수세액</a>
  <a class="btn ghost" href="/salary/">허브로 돌아가기</a>
</div>

<script>
/* =========================
   유틸
========================= */
const fmt = n => (Math.round(n)).toLocaleString('ko-KR');
const clamp0 = x => Math.max(0, Number(x) || 0);
function byId(id){ return document.getElementById(id); }

/* =========================
   요율 로드 (JSON)
   - /data/insurance-rates.json 구조:
     {
       "2025": {"np":0.045,"hi":0.03545,"ltc":0.1295,"ei":0.009},
       "2026": {"np":0.045,"hi":0.03595,"ltc":0.1314,"ei":0.009}
     }
   - ltc는 "건강보험료의 비율" (0.1295=12.95%)
========================= */
let RATE_TABLE = null;
let AUTO_RATES = null;
let YEAR_USED = "자동";

const FALLBACK_RATES = { np:0.045, hi:0.035, ltc:0.1295, ei:0.009 };

async function loadRates(){
  if (RATE_TABLE) return RATE_TABLE;
  const res = await fetch("/data/insurance-rates.json", { cache:"no-store" });
  if (!res.ok) throw new Error("insurance-rates.json 로드 실패");
  RATE_TABLE = await res.json();
  return RATE_TABLE;
}

function pickRates(table, year){
  const y = String(year);
  if (table && table[y]) return { yearUsed: y, rates: table[y], fallback:false };

  if (table && Object.keys(table).length){
    const years = Object.keys(table).map(Number).sort((a,b)=>a-b);
    const latest = String(years[years.length - 1]);
    return { yearUsed: latest, rates: table[latest], fallback:true };
  }

  return { yearUsed: "기본값", rates: FALLBACK_RATES, fallback:true };
}

function setRateInputs(r){
  // 비율(0.045) -> 입력칸은 % (4.5)
  byId("i_np").value  = (r.np * 100).toFixed(3);
  byId("i_hi").value  = (r.hi * 100).toFixed(3);
  byId("i_ei").value  = (r.ei * 100).toFixed(3);
  byId("i_ltc").value = (r.ltc * 100).toFixed(2); // 장기요양은 보통 2자리면 충분
}

function setNotice(text){
  const el = byId("rateNotice");
  if (el) el.textContent = text;
}

function getRatesFromInputs(){
  // 사용자가 비워두면 AUTO_RATES를 사용
  const np = (clamp0(byId("i_np").value)/100)  || (AUTO_RATES?.np ?? FALLBACK_RATES.np);
  const hi = (clamp0(byId("i_hi").value)/100)  || (AUTO_RATES?.hi ?? FALLBACK_RATES.hi);
  const ltc= (clamp0(byId("i_ltc").value)/100) || (AUTO_RATES?.ltc?? FALLBACK_RATES.ltc);
  const ei = (clamp0(byId("i_ei").value)/100)  || (AUTO_RATES?.ei ?? FALLBACK_RATES.ei);
  return { np, hi, ltc, ei };
}

async function applyAutoRates(){
  const nowY = new Date().getFullYear();
  try{
    const table = await loadRates();
    const picked = pickRates(table, nowY);
    AUTO_RATES = picked.rates;
    YEAR_USED = picked.yearUsed;

    setRateInputs(AUTO_RATES);
    byId("year_used").value = YEAR_USED;

    setNotice(
      picked.fallback
        ? `※ ${nowY}년 요율 데이터가 없어 ${YEAR_USED}년(최신) 요율을 기본값으로 적용했습니다.`
        : `※ ${YEAR_USED}년 요율을 기본값으로 자동 적용했습니다.`
    );
  }catch(e){
    AUTO_RATES = { ...FALLBACK_RATES };
    YEAR_USED = "기본값";
    setRateInputs(AUTO_RATES);
    byId("year_used").value = YEAR_USED;
    setNotice("※ 요율표를 불러오지 못해 기본값 요율로 계산합니다. (/data/insurance-rates.json 확인)");
    console.error(e);
  }
}

/* =========================
   계산
========================= */
function calcIns(){
  // 연봉 입력 시 월급 자동 환산(연봉이 있으면 연봉 우선)
  const annual = clamp0(byId("annual").value);
  const payInput = clamp0(byId("pay").value);
  const pay = annual > 0 ? (annual / 12) : payInput;

  if (!pay){
    alert("월 급여 또는 연봉을 입력하세요.");
    return;
  }

  // 월급 칸도 동기화(연봉에서 환산했을 때 사용자에게 보여주기)
  if (annual > 0) byId("pay").value = Math.round(pay);

  const { np, hi, ltc, ei } = getRatesFromInputs();

  const npPay = pay * np;
  const hiPay = pay * hi;
  const ltcPay = hiPay * ltc;  // 장기요양은 건강보험료 기준
  const eiPay = pay * ei;
  const sum = Math.round(npPay + hiPay + ltcPay + eiPay);

  byId("ins-out").classList.add("show");
  byId("ins-out").innerHTML = `
    <div class="card p-3">
      <div class="title">근로자 부담액(월)</div>
      <ul style="margin:8px 0 0;padding-left:18px;">
        <li>국민연금: ${fmt(npPay)} 원</li>
        <li>건강보험: ${fmt(hiPay)} 원</li>
        <li>장기요양: ${fmt(ltcPay)} 원</li>
        <li>고용보험: ${fmt(eiPay)} 원</li>
        <li><strong>합계:</strong> ${fmt(sum)} 원</li>
      </ul>
      <div class="muted" style="margin-top:10px;">
        ※ 적용 연도: <b>${YEAR_USED}</b> (고급 설정에서 요율 수정 가능)
      </div>
    </div>
  `;
}

/* =========================
   초기 실행
========================= */
window.addEventListener("DOMContentLoaded", () => {
  applyAutoRates();
});
</script>
